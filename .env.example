# ── ProtoPeek local dev config ───────────────────────────────────────────────
# Copy to .env for local dev. Prod uses .env.prod (mode 600, never committed).

SECRET_KEY=dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8904,http://127.0.0.1:8904
BASE_URL=http://127.0.0.1:8904

# Postgres (dev container on the registered port)
POSTGRES_DB=protopeek_dev
POSTGRES_USER=protopeek_user
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5547

# Redis (dev container on the registered port)
REDIS_HOST=localhost
REDIS_PORT=6494
REDIS_PASSWORD=
REDIS_DB=0

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=ProtoPeek <protopeek@brightwingsystems.com>

# OAuth — blank hides the "Continue with Google" button
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ALLOW_SIGNUPS=first_only

# Dev superuser seed (just seed-dev-superuser)
DEV_SUPERUSER_EMAIL=dev@example.com
DEV_SUPERUSER_PASSWORD=protopeek-dev

# ── Agent client config (used by the /proto-* commands, NOT the server) ──
# The agent normally keeps these in the global store ~/.config/protopeek/config (minted once, no
# signup; see /agent.md). An explicit PROTOPEEK_* env var still overrides that file.
# PROTOPEEK_BASE_URL=http://127.0.0.1:8904
# PROTOPEEK_TOKEN=pp_...
